        </div>
        <h3>Admin Dashboard</h3>
        <div class="user">
          <div id="tools">
            <% if(locals.loggedin){ %>

              <% 
                const now = new Date();
                const hour = now.getHours();
                let greeting = "👋 Hello";
                
                if (hour >= 5 && hour < 12) {
                  greeting = "🌅 Good morning";
                } else if (hour >= 12 && hour < 17) {
                  greeting = "☀️ Good afternoon";
                } else if (hour >= 17 && hour < 22) {
                  greeting = "🌆 Good evening";
                } else {
                  greeting = "🌙 Good night";
                }
              %>
      
              <a href="/account/" class="welcome-link">
                <%= greeting %>, <%= locals.accountData?.account_firstname || 'User' %>
              </a>
              <a href="/account/logout" class="logout-link"><button><i class="bi bi-box-arrow-right"></i>Logout </button></a>
            <%} else{%>
              <a title="Click to log in" href="/account/login">My Account</a>
            <%}%>
