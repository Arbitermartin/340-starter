<!-- ===== ADD VIDEO PANEL ===== -->
<div class="form-wrapper-01" id="addNewsForm">
    <div class="form-header">
      <h1>Add New Video to page</h1>
      <p>Share important updates for Videos with the UHWF community</p>
    </div>
    <div class="panel">
      <h2>Add New Video</h2>
      <% if (messages.success) { %>
        <div class="alert success"><%= messages.success %></div>
      <% } %>
      <% if (messages.notice || messages.error) { %>
        <div class="alert error"><%= messages.notice || messages.error %></div>
      <% } %>
    
      <form action="/account/inventory/add-video" method="POST">
        <div class="form-group">
          <label>Title *</label>
          <input type="text" name="title" required placeholder="Video title"/>
        </div>
        <div class="form-group">
          <label>YouTube URL *</label>
          <input type="url" name="youtube_url" id="youtube_url" required
                 placeholder="https://www.youtube.com/watch?v=..."/>
          <!-- Live preview -->
          <div id="preview" style="margin-top:10px;border-radius:8px;overflow:hidden;
                                    background:#000;min-height:50px;display:flex;
                                    align-items:center;justify-content:center;color:#aaa;">
            Paste URL above to preview
          </div>
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea name="description" rows="3" placeholder="Brief description..."></textarea>
        </div>
        <div class="form-group">
          <label>Category</label>
          <select name="category">
            <option value="General">General</option>
            <option value="Events">Events</option>
            <option value="Education">Education</option>
            <option value="Stories">Stories</option>
            <option value="Outreach">Outreach</option>
          </select>
        </div>
        <button type="submit" class="btn-submit-01">Upload Video</button>
      </form>
    
      <script>
        function extractId(url) {
          const patterns = [
            /youtu\.be\/([^?&\s]{11})/,
            /youtube\.com\/watch\?v=([^?&\s]{11})/,
            /youtube\.com\/embed\/([^?&\s]{11})/,
          ];
          for (const p of patterns) {
            const m = url.match(p);
            if (m) return m[1];
          }
          return null;
        }
        document.getElementById('youtube_url').addEventListener('input', function () {
          const id = extractId(this.value.trim());
          const preview = document.getElementById('preview');
          if (id) {
            preview.innerHTML = `<iframe width="100%" height="220"
              src="https://www.youtube.com/embed/${id}"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen style="border:none;display:block;"></iframe>`;
          } else {
            preview.innerHTML = 'Paste URL above to preview';
          }
        });
      </script>
    </div>

    
    
   