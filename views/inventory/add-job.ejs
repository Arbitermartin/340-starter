<div class="form-wrapper-01" id="addNewsForm">
    <div class="form-header">
      <h1>Add New jobs Opening</h1>
      <p>Share important updates for jobs with the UHWF community</p>
    </div>
  
    <% if (messages.success) { %>
      <div class="alert success"><%= messages.success %></div>
    <% } %>
    <% if (messages.notice || messages.error) { %>
      <div class="alert error"><%= messages.notice || messages.error %></div>
    <% } %>
    <div class="admin-section">
      <h2>Post a Job Opening</h2>
      <form action="/account/inventory/add-job" method="POST" class="news-form">
    
        <div class="form-group">
          <label>Department Name</label>
          <input type="text" name="department_name" required placeholder="e.g. Department of Social Sciences"/>
        </div>
    
        <div class="form-group">
          <label>Job Title</label>
          <input type="text" name="job_title" required placeholder="e.g. Assistant Lecturer"/>
        </div>
    
        <div class="form-group">
          <label>Number of Positions</label>
          <input type="number" name="number_of_positions" value="1" min="1" required/>
        </div>
    
        <div class="form-group">
          <label>Qualifications <small>(one per line — each becomes a roman numeral point)</small></label>
          <textarea name="qualifications" rows="6" placeholder="Applicants must hold a Master's degree...&#10;Minimum GPA of 4.0..."></textarea>
        </div>
    
        <div class="form-group">
          <label>Experience Required</label>
          <textarea name="experience" rows="3" required placeholder="A minimum of two (2) years of teaching experience is required."></textarea>
        </div>
    
        <button type="submit" class="sub">Post Job</button>
      </form>
    </div>
