<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - <%= event.title %> | UHWF Tanzania</title>
</head>
<body>

<div class="register-container">
  <div class="register-card">
    <h1 style="text-align:center; color:#2e7d32; margin-bottom:10px;">
      <%= event.title %>
    </h1>
    <p style="text-align:center; color:#555; margin-bottom:30px;">
      <%= new Date(event.event_date).toLocaleDateString('en-GB', { 
        weekday:'long', day:'numeric', month:'long', year:'numeric' 
      }) %>
    </p>

    <form action="/events/register" method="POST">
      <input type="hidden" name="event_id" value="<%= event.event_id %>">

      <div class="form-grid">
        <div>
          <label>Full Name <span style="color:red">*</span></label>
          <input type="text" name="full_name" required>
        </div>
        <div>
          <label>Phone Number <span style="color:red">*</span></label>
          <input type="tel" name="phone_number" required>
        </div>

        <div class="form-grid-full">
          <label>Email Address <span style="color:red">*</span></label>
          <input type="email" name="email" required>
        </div>

        <div>
          <label>Course of Study</label>
          <input type="text" name="course_of_study">
        </div>
        <div>
          <label>University Name</label>
          <input type="text" name="university_name">
        </div>

        <div>
          <label>Date of Birth</label>
          <input type="date" name="date_of_birth">
        </div>
        <div>
          <label>Working Experience (Years)</label>
          <input type="number" name="working_experience" min="0" value="0">
        </div>

        <div class="form-grid-full">
          <label>Company / Organization</label>
          <input type="text" name="company_name">
        </div>
      </div>

      <button type="submit" class="btn-submit">Submit Registration</button>
    </form>
  </div>
</div>

</body>
</html>