<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | UHWF Tanzania</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="body">
  <div class="login-container">
    <div class="login-card">
      <h2>Forgot Password?</h2>
      <p >Enter your registered email and we will send you a reset link.</p>

      <% if (messages.notice) { %><div class="alert error"><%= messages.notice %></div><% } %>
      <% if (messages.success) { %><div class="alert success"><%= messages.success %></div><% } %>

      <form action="/account/forgot-password" method="POST">
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" placeholder="Enter your email" required>
        </div>
        <button type="submit" class="btn-login">Send Reset Link</button>
      </form>

      <a href="/account/login" class="back-link">← Back to Login</a>
    </div>
  </div>
</body>
</html>