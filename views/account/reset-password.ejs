<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password | UHWF Tanzania</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="body">
  <div class="login-container">
    <div class="login-card">
      <h2>Reset Your Password</h2>

      <% if (messages.notice) { %><div class="alert error"><%= messages.notice %></div><% } %>
      <% if (messages.success) { %><div class="alert success"><%= messages.success %></div><% } %>

      <form action="/account/reset-password" method="POST">
        <input type="hidden" name="token" value="<%= token %>">

        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="new_password" placeholder="Enter new password" required>
        </div>

        <div class="form-group">
          <label>Confirm New Password</label>
          <input type="password" name="confirm_password" placeholder="Confirm new password" required>
        </div>

        <button type="submit" class="btn-login">Reset Password</button>
      </form>

      <a href="/account/login" class="back-link">← Back to Login</a>
    </div>
  </div>
</body>
</html>