
<div class="container">
    <div class="header-left">
      <h2 class="title">
        <span class="word">UHWF</span>
        <span class="word">TANZANIA</span>
        
      </h2>
          <p><b>Universal Human-Wildlife Foundation (UHWF) </b> is a Non-Governmental
          Organization (NGO) founded in December 2022 to operate in Tanzania
          Mainland and registered with registration number 00NGO/R/4248 under the
          Non-Governmental Organization Act, No.24 of 2002 as altered in 2019. The
          organization will operate on a national scale and strive to contribute to
          sustainable land, environmental, and natural resource management with a focus on core human-wildlife interactions through participatory land use planning,advocacy, strategic research, capacity building, and networking.</p>
          <div class="buttons">
            <a href="/account/register" class="btn btn-primary">Register Now</a>
            <a href="#" class="btn btn-secondary">Download Agreement</a>
          </div>
        
    </div>
    <div class="header-right">
      <img src="/images/site/conservation.webp" alt="environment conservation" loading="lazy">
    </div>
  </div>
  <section>
    <div class="about">
      <!-- Centered Title Section -->
    <div class="hero-title">
      <h1>We Are UHWf</h1>
      <p>United for a sustainable future — dedicated to protecting Tanzania's land, wildlife, and communities through responsible action and local empowerment.</p>
    </div>
    <div class="cards-wrapper">

      <!-- Card 1 -->
      <div class="feature-card">
        <div class="card-header">
          <i class="bi bi-arrow-repeat"></i>
          Land Use Planning
        </div>
        <div class="card-body">
          <p class="description">
            Promoting sustainable land use practices.
          </p>
          <a href="/land" class="btn-read-more">Read More</a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="feature-card card-wildlife">
        <div class="card-header">
          <i class="bi bi-shield-check"></i>
          Wildlife Conservation
        </div>
        <div class="card-body">
          <p class="description">
            Protecting Tanzania's wildlife heritage.
          </p>
          <a href="/wildlife" class="btn-read-more">Read More</a>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="feature-card card-community">
        <div class="card-header">
          <i class="bi bi-people-fill"></i>
          Community Engagement
        </div>
        <div class="card-body">
          <p class="description">
            Empowering local communities.
          </p>
          <a href="#" class="btn-read-more">Read More</a>
        </div>
      </div>

    </div>
  </div>
  </section>

  <!-- =====================================================================
         LATEST NEWS & EVENTS - Pure CSS, matches your screenshot exactly
    ====================================================================== -->
    <div class="news-events-section">
      <div class="news-events-grid">

        <!-- LEFT: LATEST NEWS -->
        <div class="news-column">
          <h2 class="section-heading">LATEST NEWS</h2>

          <% 
            // Safe defaults to prevent errors if variables are missing
            let newsItems = latestNews || [];
            let eventItems = upcomingEvents || [];
          %>

          <% if (newsItems.length > 0) { %>
            <% newsItems.forEach(item => { %>
              <div class="news-card">
                <% if (item.profile_image) { %>
                  <div class="news-image">
                    <img src="<%= item.profile_image %>" alt="<%= item.title %>" loading="lazy">
                  </div>
                <% } %>
                <div class="news-content">
                  <h3 class="news-title"><%= item.title %></h3>
                  <p class="news-text"><%= item.description.substring(0, 140) %>...</p>
                  <div class="news-footer">
                    <span class="news-date">
                      <%= new Date(item.news_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                    </span>
                    <a href="/news/<%= item.news_id %>" class="news-more">Read full update →</a>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-message">No recent news posted yet.</div>
          <% } %>
        </div>

        <!-- RIGHT: EVENTS -->
        <div class="events-column">
          <h2 class="section-heading">EVENTS</h2>

          <% if (eventItems.length > 0) { %>
            <% eventItems.forEach(item => { %>
              <div class="event-card">
                <div class="event-badge">
                  <span class="event-day"><%= new Date(item.event_date).getDate() %></span>
                  <span class="event-month"><%= new Date(item.event_date).toLocaleString('default', { month: 'short' }) %></span>
                  <span class="event-year"><%= new Date(item.event_date).getFullYear() %></span>
                </div>
                <div class="event-content">
                  <h3 class="event-title"><%= item.title %></h3>
                  <p class="event-location">
                    <i class="bi bi-geo-alt-fill"></i> <%= item.location || 'Venue TBA' %>
                  </p>
                  <p class="event-text">
                    <%= item.description ? item.description.substring(0, 100) + '...' : 'Details coming soon' %>
                  </p>
                  <a href="/events/<%= item.event_id %>" class="event-link">View event →</a>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-message">No upcoming events scheduled.</div>
          <% } %>
        </div>

      </div>
    </div>
    <!-- End of News & Events -->

  </div>
</section>
  
